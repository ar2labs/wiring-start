<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="robots" content="noindex, nofollow">

  <!-- Meta tags to control layout in mobile browsers -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>

  <!-- Shortcut icons -->
  <link rel="apple-touch-icon" href="img/apple-touch-icon.png">
  <link rel="shortcut icon" type="image/ico" href="img/favicon.ico" />

  <!-- Google Fonts for premium typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

  <!-- Styling Assets -->
  <link rel="stylesheet" href="{{ '/css/phpinfo.css' }}">

  <title>PHP Diagnostics | Wiring</title>
</head>
<body>
  <!-- Header consistent with modern UI -->
  <header class="navbar">
    <div class="container nav-wrapper">
      <a href="/" class="brand">
        <span>Wiring micro framework</span>
      </a>
      <nav class="nav-links">
        <a class="btn btn-outline" href="/">Back to home</a>
        <a class="btn btn-primary" href="/test">Test API</a>
      </nav>
    </div>
  </header>

  <!-- Main System Info Panel -->
  <main class="phpinfo-container">
    <div class="container">
      <div class="phpinfo-header center">
        <h1>PHP Environment Diagnostics</h1>
        <p class="subtitle">Complete system runtime parameters, loaded modules, and environment variables.</p>
      </div>

      <div class="phpinfo-card">
        <div class="php-info">
          {{ phpinfo | raw }}
        </div>
      </div>
    </div>
  </main>

  <!-- Diagnostics Footer -->
  <footer class="footer">
    <div class="container center">
      <p class="copyright">© {{ "now"|date("Y") }} <a href="https://github.com/ar2labs" target="_blank">AR2 Labs</a> - Open Source Community. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
